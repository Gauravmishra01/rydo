PORT=3000

# MongoDB connection string (replace with your URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>

# JWT secret used to sign tokens
JWT_SECRET=your_jwt_secret_here

# Google Maps server-side API key (optional but required for server-side geocoding)
GOOGLE_MAPS_API=YOUR_GOOGLE_MAPS_API_KEY

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
